<%- include ('../../partials/header.ejs') %>
<%- include ('../../partials/navbar.ejs') %>
<dir Class="container">
    <hr>
    <h2>Categorias</h2>
    <a class="btn btn-success" href="/admin/categories/new">New Category</a>
    <hr>
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>ID</th>
                <th>Titulo</th>
                <th>Slug</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            
            <% categories.forEach(category => { %>
                <tr>
                    <th><%= category.id %></th>
                    <th><%= category.title %></th>
                    <th><%= category.slug %></th>
                    <th>
                        <a href="/admin/categories/edit/<%= category.id %>" class="btn btn-warning">Editar</a>

                        <form method="POST" action="/categories/delete" style="display:inline;" onsubmit="confirmationdelete(event, this)">
                            <input type="hidden" name="id" value="<%= category.id %>">
                            <button class="btn btn-danger">Deletar</button>
                        </form>
                        

                    </th>
                </tr>
            <% }) %>
        </tbody>
    </table>
</dir>
<%- include ('../../partials/footer.ejs') %>
<script>
function confirmationdelete(event, form){
    event.preventDefault();
    var decision = confirm("Você deseja deletar está categoria ?");
    if(decision){
        form.submit();
    }
}

</script>