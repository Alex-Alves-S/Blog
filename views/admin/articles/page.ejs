<%- include ('../../partials/header.ejs') %>
<%- include ('../../partials/Homenavbar.ejs') %>
<body>

    <div class="container">
        <br>
        <% result.articles.rows.forEach(articles => { %>   
            <div class="card">
                <div class="card-header">
                <%= articles.title %>
                </div>
                <div class="card-body">
                    <a href="/<%= articles.slug %>" class="btn btn-primary">Ler artigo</a>
                </div>
            </div>
            <br>

        <% }) %>

        <div class="row">
            <div class="col col-12">
                <% if (result.page > 2) {%>
                    <a style="float:left;" href="/articles/page/<%= result.page - 1 %>"><< Prev</a>
                <% } else if(result.page == 2) {%>
                    <a style="float:left;" href="/"><< Prev</a>
                <% } %>
                <% if(result.next) {%>
                    <a style="float: right;" href="/articles/page/<%= result.page + 1 %>">next >></a>
                <% } %>
            </div>
            <hr>
        </div>
        <hr>        

    </div>

</body>

<%- include ('../../partials/footer.ejs') %>